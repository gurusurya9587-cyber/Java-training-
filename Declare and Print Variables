import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();       
        double d = sc.nextDouble(); 
        sc.nextLine();              
        String s = sc.nextLine();   

        System.out.println(n);      
        System.out.println(d);      
        System.out.println(s);     
    }
}
